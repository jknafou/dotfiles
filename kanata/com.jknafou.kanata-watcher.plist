<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.jknafou.kanata-watcher</string>
  <key>ProgramArguments</key>
  <array>
      <string>/usr/bin/pkill</string>
      <string>-x</string>
      <string>kanata</string>
  </array>
  <key>WatchPaths</key>
  <array>
      <string>/dev</string>
  </array>
  <key>ThrottleInterval</key>
  <integer>5</integer>
  <key>StandardOutPath</key>
  <string>/Library/Logs/Kanata/kanata-watcher.out.log</string>
  <key>StandardErrorPath</key>
  <string>/Library/Logs/Kanata/kanata-watcher.err.log</string>
</dict>
</plist>
