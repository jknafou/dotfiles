#!/bin/bash
# Start kanata keyboard remapper

# Ensure vhid-daemon is running
sudo /bin/launchctl bootstrap system /Library/LaunchDaemons/com.jknafou.vhid-daemon.plist 2>/dev/null || true

# Clear any stale disable override
sudo /bin/launchctl enable system/com.jknafou.kanata 2>/dev/null || true

# Ensure clean state: bootout if loaded, wait for launchd to fully unload
sudo /bin/launchctl bootout system/com.jknafou.kanata 2>/dev/null || true
sleep 1

if sudo /bin/launchctl bootstrap system /Library/LaunchDaemons/com.jknafou.kanata.plist; then
    echo "kanata started"
else
    echo "kanata failed to start — check: sudo cat /Library/Logs/Kanata/kanata.err.log" >&2
    exit 1
fi
